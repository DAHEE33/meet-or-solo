# 공통
SERVER_PORT=8080

# local: 개인 PC Docker PostgreSQL
SPRING_PROFILES_ACTIVE=local
POSTGRES_DB=meet_or_solo_local
POSTGRES_USER=meet_user
POSTGRES_PASSWORD=meet_password
DB_HOST=localhost
DB_PORT=5432
LOCAL_DB_URL=jdbc:postgresql://localhost:5432/meet_or_solo_local

# dev: Oracle Cloud VM 개발/시연용 DB
DEV_DB_URL=jdbc:postgresql://<DEV_DB_HOST>:5432/meet_or_solo_dev
DEV_DB_USERNAME=<DEV_DB_USERNAME>
DEV_DB_PASSWORD=<DEV_DB_PASSWORD>

# Spring Boot dev profile은 아래 DB_URL 계열 환경변수를 읽는다.
# dev 서버에서 SPRING_PROFILES_ACTIVE=dev와 함께 설정한다.
DB_URL=jdbc:postgresql://<DEV_DB_HOST>:5432/meet_or_solo_dev
DB_USERNAME=<DEV_DB_USERNAME>
DB_PASSWORD=<DEV_DB_PASSWORD>

# prod: 추후 운영 분리용 DB
PROD_DB_URL=jdbc:postgresql://<PROD_DB_HOST>:5432/meet_or_solo_prod
PROD_DB_USERNAME=<PROD_DB_USERNAME>
PROD_DB_PASSWORD=<PROD_DB_PASSWORD>
