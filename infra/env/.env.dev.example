SPRING_PROFILES_ACTIVE=dev
TZ=Asia/Seoul
PGTZ=Asia/Seoul

POSTGRES_DB=meet_or_solo_dev
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME

DB_URL=jdbc:postgresql://postgres:5432/meet_or_solo_dev
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME

CORS_ALLOWED_ORIGINS=http://<DEV_SERVER_HOST>:18080
FRONTEND_BASE_URL=http://<DEV_SERVER_HOST>:18080
AUTH_COOKIE_SECURE=false
# AES-256: 임의의 32바이트 key를 표준 Base64로 인코딩한 값
PROFILE_ENCRYPTION_KEY=<BASE64_ENCODED_32_BYTE_KEY>
SERVER_PORT=8080

OCI_OBJECT_STORAGE_ENDPOINT=https://<OBJECT_STORAGE_NAMESPACE>.compat.objectstorage.<OCI_REGION>.oraclecloud.com
OCI_OBJECT_STORAGE_REGION=<OCI_REGION>
OCI_OBJECT_STORAGE_ACCESS_KEY=<OCI_CUSTOMER_SECRET_KEY_ACCESS_KEY>
OCI_OBJECT_STORAGE_SECRET_KEY=<OCI_CUSTOMER_SECRET_KEY_SECRET>
OCI_OBJECT_STORAGE_BUCKET=meet-or-solo-assets
OCI_OBJECT_STORAGE_PROFILE_PREFIX=profiles/dev
PROFILE_IMAGE_MAX_SIZE=5MB

KAKAO_CLIENT_ID=<KAKAO_REST_API_KEY>
KAKAO_CLIENT_SECRET=<KAKAO_CLIENT_SECRET>
KAKAO_REDIRECT_URI=http://<DEV_SERVER_HOST>:18080/api/auth/kakao/callback
NAVER_CLIENT_ID=<NAVER_CLIENT_ID>
NAVER_CLIENT_SECRET=<NAVER_CLIENT_SECRET>
NAVER_REDIRECT_URI=http://<DEV_SERVER_HOST>:18080/api/auth/naver/callback
JWT_SECRET=<JWT_SECRET_AT_LEAST_32_BYTES>
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRES_MINUTES=20160
